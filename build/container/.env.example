# build/container/.env.example
#
# Copy to build/container/.env (or export these as shell vars, or let
# scripts/deploy-container.sh compute them for you) before running
# `docker compose -f build/container/compose.yml up`.
#
# compose.yml requires these three as plain, non-defaulted variables rather
# than expanding $XDG_DATA_HOME/etc itself — see compose.yml's own
# "Persistence" header comment for why (podman-compose's interpolation
# cannot handle the nested-${VAR} form a portable in-file default would
# need). scripts/deploy-container.sh computes correct values for the
# common case (the same $XDG_*_HOME-or-fallback convention cmd/start.go
# uses) and exports them for you — this file exists for a manual
# `docker compose` invocation or a non-default layout.
#
# PR6 REMINDER (docs/plans/phase6-container-backend.md §PR6): the stack
# this .env feeds is a skeleton. Do not run it against a real
# ~/.local/share/boid / ~/.config/boid you care about yet.

# Host path bind-mounted to the container boid user's
# $HOME/.local/share/boid (SQLite DB, runtimes/, workspace homes/, kits/,
# the mTLS CA, install_id, web_secret). Matches cmd/start.go's
# defaultDBPath/defaultInstallIDDir convention: $XDG_DATA_HOME/boid, or
# $HOME/.local/share/boid when XDG_DATA_HOME is unset.
BOID_DATA_DIR=/home/YOUR_USER/.local/share/boid

# Host path bind-mounted to the container boid user's $HOME/.config/boid
# (config.yaml, workspaces/*.yaml, host_commands.yaml). Matches
# internal/config.Load's convention: $XDG_CONFIG_HOME/boid, or
# $HOME/.config/boid when XDG_CONFIG_HOME is unset.
BOID_CONFIG_DIR=/home/YOUR_USER/.config/boid

# Host path bound at the SAME path inside the container — the "server
# socket host-path mutual exclusion" mechanism (compose.yml's own comment).
# Matches client.DefaultSocketPath()'s convention: $XDG_RUNTIME_DIR, or
# /run/user/<uid> when unset. Must be the exact directory the host's own
# `boid start` (the "旧デプロイ" this stack can roll back to) would resolve
# too, or the two deploys cannot see each other's socket.
BOID_RUNTIME_DIR=/run/user/1000

# Must match the uid/gid build/container/Dockerfile was built with
# (BOID_UID/BOID_GID build args, default 1000:1000) AND the host uid that
# owns BOID_DATA_DIR/BOID_CONFIG_DIR/BOID_RUNTIME_DIR above.
BOID_UID=1000
BOID_GID=1000

# The host's `docker` group GID (Major 9, PR6 codex review). compose.yml
# adds this as a supplementary group (group_add) on the non-root daemon
# process so it can open /var/run/docker.sock (DooD, typically owned
# root:docker mode 0660) — without it, every docker API call from inside
# the container fails with a permission error. Find yours with:
#   getent group docker | cut -d: -f3
# scripts/deploy-container.sh resolves and exports this for you
# automatically; set it here only for a manual `docker compose`/
# `podman-compose` invocation.
DOCKER_GID=999
