#!/usr/bin/env bash
set -euo pipefail

log_file="${E2E_STATE_DIR:?}/fake-git.log"
{
  printf 'cmd=git\n'
  printf 'cwd=%s\n' "$PWD"
  printf 'args=%s\n' "$*"
  printf -- '---\n'
} >>"$log_file"

# Parse past optional -C <dir>
args=("$@")
idx=0
if [[ "${args[$idx]:-}" == "-C" ]]; then
  idx=$((idx + 2))
fi

subcmd="${args[$idx]:-}"

if [[ "$subcmd" == "worktree" ]]; then
  action="${args[$((idx + 1))]:-}"
  case "$action" in
    add)
      # git worktree add [-b <branch>] <path> [<commit>]
      i=$((idx + 2))
      if [[ "${args[$i]:-}" == "-b" ]]; then
        i=$((i + 2))  # skip -b and branch name
      fi
      wt_path="${args[$i]:-}"
      if [[ -n "$wt_path" ]]; then
        mkdir -p "$wt_path"
      fi
      ;;
    remove)
      # git -C <dir> worktree remove [--force] <path>
      i=$((idx + 2))
      while [[ "${args[$i]:-}" == --* ]]; do
        i=$((i + 1))
      done
      wt_path="${args[$i]:-}"
      if [[ -n "$wt_path" && "$wt_path" != "/" ]]; then
        rm -rf "$wt_path"
      fi
      ;;
  esac
fi

exit 0
