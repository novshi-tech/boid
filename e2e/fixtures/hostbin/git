#!/usr/bin/env bash
set -euo pipefail

log_file="${E2E_STATE_DIR:?}/fake-git.log"
{
  printf 'cmd=git\n'
  printf 'cwd=%s\n' "$PWD"
  printf 'args=%s\n' "$*"
  printf -- '---\n'
} >>"$log_file"

# Parse past optional -C <dir>
args=("$@")
idx=0
cdir=""
if [[ "${args[$idx]:-}" == "-C" ]]; then
  cdir="${args[$((idx + 1))]:-}"
  idx=$((idx + 2))
fi

subcmd="${args[$idx]:-}"

# Return the current branch for a given directory.
# Reads HEAD file if present; defaults to "main" for directories without one.
_fake_head_branch() {
  local dir="${1:-$PWD}"
  local head_file="${dir}/HEAD"
  if [[ -f "$head_file" ]]; then
    local content
    content=$(cat "$head_file")
    # "ref: refs/heads/foo" → "foo"; bare SHA or anything else → ""
    local branch="${content#ref: refs/heads/}"
    if [[ "$branch" != "$content" ]]; then
      printf '%s' "$branch"
    fi
    # detached HEAD: print nothing (caller interprets empty as detached)
  else
    printf 'main'
  fi
}

if [[ "$subcmd" == "worktree" ]]; then
  action="${args[$((idx + 1))]:-}"
  case "$action" in
    add)
      # git worktree add [--no-track] [-b <branch>] <path> [<commit>]
      i=$((idx + 2))
      while [[ "${args[$i]:-}" == --* ]]; do
        i=$((i + 1))  # skip flags like --no-track, --detach, etc.
      done
      branch_name=""
      if [[ "${args[$i]:-}" == "-b" || "${args[$i]:-}" == "-B" ]]; then
        branch_name="${args[$((i + 1))]:-}"
        i=$((i + 2))  # skip -b/-B and branch name
      fi
      wt_path="${args[$i]:-}"
      if [[ -n "$wt_path" ]]; then
        mkdir -p "$wt_path"
        if [[ -n "$branch_name" ]]; then
          printf 'ref: refs/heads/%s\n' "$branch_name" > "${wt_path}/HEAD"
        fi
      fi
      ;;
    remove)
      # git -C <dir> worktree remove [--force] <path>
      i=$((idx + 2))
      while [[ "${args[$i]:-}" == --* ]]; do
        i=$((i + 1))
      done
      wt_path="${args[$i]:-}"
      if [[ -n "$wt_path" && "$wt_path" != "/" ]]; then
        rm -rf "$wt_path"
      fi
      ;;
  esac
elif [[ "$subcmd" == "config" ]]; then
  # git config --get remote.origin.url — used by internal/dispatcher.
  # GitOriginURL / CaptureUpstreamURL for PR2 upstream_url capture
  # (docs/plans/git-gateway-cutover.md). Fake git has no real remote state
  # (scenario fixtures are plain directories, not git repos — no /usr/bin/git
  # init happens for them), so report a fixed placeholder for any
  # remote.origin.url lookup. This is a stand-in for PR7a's real
  # fixture-upstream-server harness, just enough for `project add` / `project
  # reload` to see *some* origin during e2e. Anything else: "not found",
  # matching real git's exit 1 for a missing config key.
  key=""
  for arg in "${args[@]:$((idx + 1))}"; do
    case "$arg" in
      --get|-*) ;;
      *) key="$arg" ;;
    esac
  done
  if [[ "$key" == "remote.origin.url" ]]; then
    printf 'https://example.invalid/e2e/fake-repo.git\n'
    exit 0
  fi
  exit 1
elif [[ "$subcmd" == "symbolic-ref" ]]; then
  # git symbolic-ref [--quiet] HEAD  →  "refs/heads/<branch>" or nothing for detached
  head_dir="${cdir:-$PWD}"
  branch="$(_fake_head_branch "$head_dir")"
  if [[ -n "$branch" ]]; then
    printf 'refs/heads/%s\n' "$branch"
  fi
elif [[ "$subcmd" == "rev-parse" ]]; then
  # Handle: git rev-parse --abbrev-ref HEAD  →  branch name (or "HEAD" for detached)
  # Handle: git rev-parse HEAD               →  fake SHA
  # Handle: git rev-parse --verify --quiet <ref>  →  exit 0 if ref exists (fake: always OK)
  head_dir="${cdir:-$PWD}"
  abbrev=0
  want_verify=0
  target=""
  for arg in "${args[@]:$((idx + 1))}"; do
    case "$arg" in
      --abbrev-ref) abbrev=1 ;;
      --verify) want_verify=1 ;;
      --quiet) ;;
      -*) ;;
      *) target="$arg" ;;
    esac
  done
  if [[ "$abbrev" -eq 1 && "$target" == "HEAD" ]]; then
    branch="$(_fake_head_branch "$head_dir")"
    if [[ -n "$branch" ]]; then
      printf '%s\n' "$branch"
    else
      printf 'HEAD\n'  # detached
    fi
  elif [[ "$want_verify" -eq 0 && "$target" == "HEAD" ]]; then
    # git rev-parse HEAD → fake SHA
    printf 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\n'
  fi
  # --verify: exit 0 (ref always "exists" in fake git)
fi

exit 0
