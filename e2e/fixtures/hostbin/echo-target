#!/usr/bin/env bash
set -euo pipefail

# Deliberately named differently from the host_commands.<name> declared in
# e2e/fixtures/kits/host-ops/kit.yaml ("alias-echo"): this is the 5a-3
# regression fixture (docs/plans/phase5-shim-and-task-context.md 5a PR3
# cutover). Post cutover, the dispatcher materializes a symlink at
# /opt/boid/bin/alias-echo (declared name) pointing at the boid multi-call
# binary, and the agent invokes it as `alias-echo` (see the hook in the
# scenario's project.yaml). This host-side file name intentionally still
# differs to prove the alias mapping — if the dispatcher ever regressed to
# creating the symlink under the source basename (`echo-target`) instead,
# the hook's `alias-echo` invocation would fail command-not-found.
log_file="${E2E_STATE_DIR:?}/fake-alias-echo.log"
{
  printf 'cmd=echo-target\n'
  printf 'cwd=%s\n' "$PWD"
  printf 'args=%s\n' "$*"
  printf -- '---\n'
} >>"$log_file"
