#!/usr/bin/env bash
set -euo pipefail

# Deliberately named differently from the host_commands.<name> declared in
# e2e/fixtures/kits/host-ops/kit.yaml ("alias-echo"): this is the 5a-2
# regression fixture (docs/plans/phase5-shim-and-task-context.md, codex
# review Minor finding on 5a-1) — a host_commands.<name>.path alias means the
# file the sandbox actually sees (and the agent actually invokes) has a
# basename that differs from the declared short name, mirroring
# host_commands.run-e2e -> e2e/run.sh in this repo's own workspace config.
# If the shim ever regresses to resolving its broker-facing command name from
# argv0's basename alone, this script's invocation would report itself as
# "echo-target" instead of "alias-echo" and the broker would reject it.
log_file="${E2E_STATE_DIR:?}/fake-alias-echo.log"
{
  printf 'cmd=echo-target\n'
  printf 'cwd=%s\n' "$PWD"
  printf 'args=%s\n' "$*"
  printf -- '---\n'
} >>"$log_file"
