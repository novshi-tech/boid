# Template for: dotnet-dev
# Detection signal: `which dotnet` 成功
# Variables to substitute:
#   {{dotnet_binary}}  = dotnet binary の絶対パス
#                        確認: which dotnet
#   {{dotnet_root}}    = .NET SDK のインストールディレクトリ (hostfxr 探索ルート)
#                        確認: 以下のいずれかで取得
#                          1. 環境変数 $DOTNET_ROOT が設定されていればそれ
#                          2. Ubuntu apt 標準: /usr/lib/dotnet
#                          3. RHEL/SUSE 系: /usr/share/dotnet
#                          4. 上記が無い場合: dirname "$(readlink -f "$(which dotnet)")"
#                             (snap / 手動展開 / asdf 等)
#   {{dotnet_version}} = .NET SDK バージョン
#                        確認: dotnet --version
#
# Note: ~/.nuget/ と ~/.dotnet/ は user-local の SDK state (package cache /
#   first-run sentinel 等) を持つので rw bind が必要。
# Note: NuGet API key は ~/.nuget/NuGet/NuGet.Config に clearTextPassword で
#   入りうるが、 kit.yaml に生値を書いてはいけない (secret-free 規約)。
#   bind マウント経由で渡せばファイル側で完結する。
# Note: snap install dotnet-sdk の場合、 dotnet binary は /snap/bin/dotnet で
#   実体は /snap/dotnet-sdk/current。 DOTNET_ROOT もそれに合わせる。

meta:
  name: dotnet-dev
  description: ".NET SDK (v{{dotnet_version}})"
  category: language
  generated_at: "YYYY-MM-DD"
  generated_by: boid-kit-init

requires:
  commands:
    - dotnet

env:
  DOTNET_ROOT: {{dotnet_root}}
  DOTNET_CLI_TELEMETRY_OPTOUT: "1"
  DOTNET_NOLOGO: "1"

additional_bindings:
  - source: {{dotnet_root}}
  - source: ${HOME}/.nuget
    mode: rw
  - source: ${HOME}/.dotnet
    mode: rw
