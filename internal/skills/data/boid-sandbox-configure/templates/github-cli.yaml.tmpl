# Template for: github-cli
# Detection signal: `which gh` succeeded
# Variables to substitute:
#   {{gh_binary}} = gh binary の絶対パス
#                   確認: which gh
#
# Note: GH_TOKEN は secret: 参照を使う。生値は絶対に書かない。
#   gh CLI は ~/.config/gh/hosts.yml に認証情報を持つ。
#   サンドボックス内では GH_TOKEN env または gh auth token で解決される。
#
#   allow リストは実際に必要なサブコマンドのみ残す (ホワイトリスト制)。
#   追加が必要なら手動で kit.yaml を編集する。
#
#   gh は host 側で中立ディレクトリ (repo checkout でない cwd) から実行される
#   ため、GH_REPO を env で明示して repo 文脈を渡す。${boid:repo_slug} は
#   token 登録時に project の origin remote から `host/owner/repo` 形式で
#   自動導出される。
#
#   --body-file はサンドボックス内のファイルパスを host 側 gh プロセスが読め
#   ないため reject ルールで明示拒否し、代替手段 (--body "$(cat <file>)") を
#   reason で案内する。

meta:
  name: github-cli
  description: GitHub CLI (gh) をサンドボックスに提供する
  category: ci
  generated_at: "YYYY-MM-DD"
  generated_by: boid-kit-init

host_commands:
  gh:
    path: {{gh_binary}}
    allow:
      - pr
      - issue
      - repo
      - release
      - run
      - workflow
      - label
      - milestone
      - api
      - auth
    env:
      GH_TOKEN: "secret:"
      GH_REPO: ${boid:repo_slug}
    reject:
      - match: "*--body-file*"
        reason: 'サンドボックスのファイルパスは host からは見えない。--body "$(cat <file>)" で内容を渡す'
