# Template for: go-dev
# Detection signal: `which go` succeeded
# Variables to substitute:
#   {{gopath}}      = GOPATH
#                     確認: go env GOPATH
#   {{goroot}}      = GOROOT
#                     確認: go env GOROOT
#   {{gomodcache}}  = GOMODCACHE (module ダウンロードキャッシュ、 既定 $GOPATH/pkg/mod)
#                     確認: go env GOMODCACHE
#   {{gocache}}     = GOCACHE (build キャッシュ、 既定 ~/.cache/go-build)
#                     確認: go env GOCACHE
#   {{go_version}}  = Go のバージョン
#                     確認: go version | awk '{print $3}'
#
# Note: go コマンドは **サンドボックス内で直接実行する**。 host_commands には
#   登録しない (ローカルなツールチェインであり、 ホストの credential や特権を
#   必要としないため)。 {{goroot}} を bind して PATH に {{goroot}}/bin を通す
#   ことで、 go コンパイラがサンドボックス内の shell から普通に発見される。
#
# Note: go install でインストールしたツール (~/$GOPATH/bin) もバインドが必要な場合は
#   additional_bindings に {{gopath}}/bin を追加する (本テンプレでは既に追加済)。
#   ただしサンドボックス内からの go install は CGO や外部 module zip のため
#   制限される場合がある (sandbox egress 制約)。
#
# Note (パッケージキャッシュの永続化 — 重要): サンドボックスの $HOME は dispatch 毎に
#   tmpfs で作り直されるため、 module cache ({{gomodcache}}) と build cache ({{gocache}})
#   を bind しないと **毎回キャッシュが空** になり、 go build/test の度に全モジュールを
#   再ダウンロード・再コンパイルする。 これを防ぐため両キャッシュをホストから
#   **mode: rw** で bind する (go はキャッシュに書き込むので ro 不可)。
#   - bind 元が host に存在しない場合は事前に host 側で `mkdir -p` しておくこと
#     (bind source が無いと dispatch のマウントが失敗する)。
#   - sandbox 内 $HOME と host の $HOME が一致する構成なら GOMODCACHE/GOCACHE は
#     既定値で bind 先と一致するが、 取り違え防止のため env で明示する。

meta:
  name: go-dev
  description: "Go development toolchain ({{go_version}})"
  category: language
  generated_at: "YYYY-MM-DD"
  generated_by: boid-kit-init

env:
  GOPATH: {{gopath}}
  GOROOT: {{goroot}}
  GOMODCACHE: {{gomodcache}}
  GOCACHE: {{gocache}}
  PATH: "{{goroot}}/bin:{{gopath}}/bin:${PATH}"

additional_bindings:
  - source: {{goroot}}
  - source: {{gopath}}/bin
  # module ダウンロードキャッシュ / build キャッシュは dispatch 跨ぎで永続化する。
  # go が書き込むため mode: rw 必須。
  - source: {{gomodcache}}
    mode: rw
  - source: {{gocache}}
    mode: rw
