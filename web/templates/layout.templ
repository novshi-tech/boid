package templates

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="ja">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title } - boid</title>
			<link rel="stylesheet" href="/static/style.css"/>
		</head>
		<body>
			<nav>
				<a href="/">Tasks</a>
				<a href="/projects">Projects</a>
			</nav>
			{ children... }
		</body>
	</html>
}
