package templates

import "github.com/novshi-tech/boid/web/templates/components"

// TerminalPage renders the full-screen PTY terminal for an interactive running job.
// title should be built from jobPageTitle (e.g. "[main] claude-code").
// jobId is the job UUID; wsPath is /api/jobs/{id}/attach/ws.
templ TerminalPage(title string, backURL string, jobId string, wsPath string) {
	@Layout(title, backURL) {
		<style>
			html, body { overflow: hidden; height: 100%; }
			.site-main {
				display: flex;
				flex-direction: column;
				height: calc(100vh - 48px);
				padding: 0;
				overflow: hidden;
			}
			@media (min-width: 768px) {
				.site-main {
					max-width: 100%;
					margin: 0;
					padding: 0;
				}
			}
		</style>
		@components.Terminal(jobId, wsPath)
	}
}

// TerminalNotReady renders an error page when a job is not running.
templ TerminalNotReady(jobId string, reason string) {
	@Layout("Terminal Not Available", "/jobs/"+jobId) {
		<div class="detail-card task-row-status-pending">
			<div class="detail-meta">
				<span>Not connected</span>
			</div>
		</div>
		<p class="empty-state">{ reason }</p>
		<p><a href={ templ.SafeURL("/jobs/" + jobId) }>← Back to job</a></p>
	}
}
