package templates

import (
	"fmt"
	"net/url"
	"time"

	"github.com/novshi-tech/boid/web/templates/components"
)

// gateReplayPath は gate ID が '/' を含む (kit-name/gate-name 形式) ため、
// chi の単一セグメント match に合わせて %2F へエンコードする。
// 素のまま連結すると 404 になる (CLI/TUI と同じ罠なので共通化)。
func gateReplayPath(taskID, gateID string) string {
	return fmt.Sprintf("/tasks/%s/gates/%s/replay", url.PathEscape(taskID), url.PathEscape(gateID))
}

// hookReplayPath は hook ID が '/' を含む (kit-name/hook-name 形式) ため、
// chi の単一セグメント match に合わせて %2F へエンコードする。
func hookReplayPath(taskID, hookID string) string {
	return fmt.Sprintf("/tasks/%s/hooks/%s/replay", url.PathEscape(taskID), url.PathEscape(hookID))
}

type JobContextView struct {
	ID          string
	TaskID      string
	TaskTitle   string
	HandlerID   string
	Role        string
	GateID      string // set when job is a gate job; used for gate replay form
	HookID      string // set when job is a hook job; used for hook replay form
	Status      string
	ExitCode    int
	Interactive bool // true = PTY output contains ANSI redraw sequences; don't live-follow
	CreatedAt   time.Time
	UpdatedAt   time.Time
	Output      string
}

// jobStatusStripe maps a job status to the task-row-status-* class so the
// detail header reuses the task list's left-edge colour palette.
//
//	pending   → slate (same as task pending)
//	running   → green (same as task executing)
//	completed → gray  (same as task done)
//	failed    → red   (same as task aborted)
func jobStatusStripe(status string) string {
	switch status {
	case "running":
		return "task-row-status-executing"
	case "completed":
		return "task-row-status-done"
	case "failed":
		return "task-row-status-aborted"
	default:
		return "task-row-status-pending"
	}
}

// jobPageTitle builds the page-header title from the job's identity
// (role + handler), e.g. "[hook] claude-code/run-agent". The job's own
// UUID is demoted to the detail-meta row — UUIDs are unreadable at a
// glance, while "what hook/gate ran" is the question most readers are
// actually trying to answer on this page.
func jobPageTitle(job *JobContextView) string {
	switch {
	case job.Role != "" && job.HandlerID != "":
		return "[" + job.Role + "] " + job.HandlerID
	case job.HandlerID != "":
		return job.HandlerID
	case job.Role != "":
		return "[" + job.Role + "]"
	default:
		return "Job " + shortID(job.ID)
	}
}

templ JobDetail(job *JobContextView) {
	@Layout(jobPageTitle(job), "/tasks/"+job.TaskID) {
		<div class={ "detail-card", jobStatusStripe(job.Status) }>
			<div class="detail-meta">
				<span class={ taskStatusClass(job.Status) }>{ job.Status }</span>
				<span class="detail-meta-sep">·</span>
				<span class="job-id">{ job.ID }</span>
				if job.ExitCode != 0 {
					<span class="detail-meta-sep">·</span>
					<span class="exit-code">exit { fmt.Sprintf("%d", job.ExitCode) }</span>
				}
				<span class="detail-meta-sep">·</span>
				<span class="detail-time">{ job.UpdatedAt.Format("2006-01-02 15:04") }</span>
			</div>
		</div>
		<section class="job-output">
			<h2 class="section-title">Output</h2>
			if job.Interactive && job.Status == "running" {
				@components.Terminal(job.ID, "/api/jobs/"+job.ID+"/attach/ws")
			} else if job.Interactive {
				// 完了後の transcript は ANSI エスケープを含むため TUI 再現は不能。
				<p class="job-log-note">
					このジョブはインタラクティブです。リアルタイム出力は表示できません
					&mdash; 完了後の transcript は ANSI エスケープシーケンスを含むため TUI 再現は不能です。
				</p>
				if job.Output != "" {
					<pre id="job-log" class="job-log">{ job.Output }</pre>
				}
			} else {
				<pre id="job-log" class="job-log" data-job-id={ job.ID }>{ job.Output }</pre>
				if job.Status == "running" || job.Status == "pending" {
					<script>
						(function() {
							var pre = document.getElementById('job-log');
							var es = new EventSource('/api/jobs/' + pre.dataset.jobId + '/log?follow=true');
							es.onmessage = function(e) {
								var span = document.createElement('span');
								span.textContent = e.data + '\n';
								pre.appendChild(span);
								pre.scrollTop = pre.scrollHeight;
							};
							es.onerror = function() { es.close(); };
						})();
					</script>
				}
			}
		</section>
		if job.GateID != "" || job.HookID != "" || (job.Interactive && job.Status == "running") {
			<div class="action-bar">
				<div class="action-bar-inner">
					if job.GateID != "" {
						<form method="post" action={ templ.SafeURL(gateReplayPath(job.TaskID, job.GateID)) } onsubmit="return confirm('本当にゲートを再発火しますか？')" class="action-bar-primary-form">
							<button type="submit" class="btn btn-primary">Replay gate</button>
						</form>
					}
					if job.HookID != "" {
						<form method="post" action={ templ.SafeURL(hookReplayPath(job.TaskID, job.HookID)) } onsubmit="return confirm('本当にフックを再発火しますか？')" class="action-bar-primary-form">
							<button type="submit" class="btn btn-primary">Replay hook</button>
						</form>
					}
					<span class="action-bar-spacer"></span>
					if job.Interactive && job.Status == "running" {
						<a href={ templ.SafeURL("/jobs/" + job.ID + "/terminal") } target="_blank" rel="noopener" class="btn btn-secondary">全画面で開く</a>
					}
				</div>
			</div>
		}
	}
}
