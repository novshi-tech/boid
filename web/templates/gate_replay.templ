package templates

import (
	"github.com/novshi-tech/boid/internal/orchestrator"
)

templ GateReplayList(taskID, status string, gates []orchestrator.Gate, errorMsg string) {
	@Layout("Gate Replay", "/tasks/"+taskID) {
		if errorMsg != "" {
			<div class="card action-error">
				{ errorMsg }
			</div>
		}
		<div class="card">
			if len(gates) == 0 {
				<p style="color:#888">No replayable gates for this task.</p>
			} else {
				<div class="job-list">
					for _, gate := range gates {
						<div class="job-row">
							<div class="job-row-header">
								<span class="job-id">{ gate.ID }</span>
								<span class="badge">{ string(gate.Phase) }</span>
								if gate.Kit != "" {
									<span>{ gate.Kit }</span>
								}
							</div>
							<div style="margin-top:8px">
								<form method="post" action={ templ.SafeURL(gateReplayPath(taskID, gate.ID)) } onsubmit="return confirm('Replay this gate?')">
									<button type="submit" class="btn btn-primary">replay</button>
								</form>
							</div>
						</div>
					}
				</div>
			}
		</div>
	}
}
